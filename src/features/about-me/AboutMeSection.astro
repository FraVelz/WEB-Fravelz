---
import { getTranslations, type Language } from "@/utils/i18n";

const lang = Astro.params.lang as Language;
const t = getTranslations(lang);

const history = [
  [t.about_history_text, "2017"],
  [t.about_modal_paragraph1, "2018-2021"],
  [t.about_modal_paragraph2, "2021"],
  [t.about_modal_paragraph3, "2021-2024"],
  [t.about_modal_paragraph4, "2025"],
  [t.about_modal_paragraph5, "+2026"],
];

interface Props {
  classname?: string;
}

const { classname = "" } = Astro.props;
---

<section id="about-me" class={classname}>
  <div
    class="relative flex justify-between items-center h-fit lg:h-screen w-full mx-auto max-lg:flex-col max-lg:items-start"
  >
    <h2
      class="lg:absolute lg:top-32 left-0 w-full text-center text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4"
      data-i18n="info_about_title"
    >
      {t.info_about_title || "Sobre Mí"}
    </h2>

    <!-- Línea -->
    <div
      class="about-timeline-line absolute top-1/2 left-0 w-full h-1 -translate-y-1/2 z-10
              max-lg:top-0 max-lg:left-5 max-lg:w-1 max-lg:h-full max-lg:translate-y-0"
    >
    </div>

    {
      history.map((value, index) => (
        <div
          class={`relative min-w-45 w-full text-center z-20 
                  max-lg:mb-12 max-lg:pl-12
                  `}
        >
          <div
            class={`absolute text-left lg:text-center h-fit w-45 py-4 rounded-lg
                    ${index % 2 === 0 ? "bottom-10" : "top-10"}
                    max-lg:relative max-lg:top-0 max-lg:bottom-0 max-lg:w-full`}
          >
            <div class="about-timeline-year font-bold mb-2">{value[1]}</div>

              { (index!==0 && index!==history.length-1) ? (
                <div class="lg:relative lg:w-60 lg:left-[50%] lg:translate-x-[-50%]">
                  {value[0]}
                </div>

              ) : ( value[0] )} 

            {(value[1]=='2021') ? (
              <a
                href="https://github.com/divelz"
                target="_blank"
                rel="noopener noreferrer"
                class="about-link inline-flex items-center gap-2 font-semibold underline underline-offset-4 transition-colors"
              >
                Github
              </a>
            ) : (
              <></>
            )
            }
          </div>

          <div
            class="about-timeline-dot w-5 h-5 rounded-full mx-auto
                    max-lg:absolute max-lg:top-5 max-lg:left-[11px]"
          />
        </div>
      ))
    }
  </div>
</section>

<style>
  .about-timeline-line,
  .about-timeline-dot {
    background-color: rgb(var(--color-primary));
  }

  .about-timeline-year {
    color: rgb(var(--color-primary));
  }

  .about-link {
    color: rgb(var(--color-primary));
  }
  .dark .about-link {
    color: rgb(var(--color-primary));
  }
  .about-link:hover {
    color: rgb(var(--color-primary-hover));
  }
  .dark .about-link:hover {
    color: rgb(var(--color-primary-hover));
  }
  .about-link:focus-visible {
    outline: none;
    box-shadow:
      0 0 0 2px rgb(var(--color-primary)),
      0 0 0 4px rgb(var(--color-surface));
  }
  .dark .about-link:focus-visible {
    box-shadow:
      0 0 0 2px rgb(var(--color-primary)),
      0 0 0 4px rgb(var(--color-bg));
  }
</style>
