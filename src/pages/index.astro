---
export const prerender = false;
import {
  isValidLanguage,
  localePathFromAcceptHeader,
} from "@/utils/i18n";

// Check for language in cookies
const cookieLang = Astro.cookies.get("lang")?.value;

if (cookieLang && isValidLanguage(cookieLang)) {
  return Astro.redirect(`/${cookieLang}/`);
}

const nextPath = localePathFromAcceptHeader(
  Astro.request.headers.get("accept-language"),
);
if (nextPath) {
  return Astro.redirect(nextPath);
}
return Astro.redirect("/es/");
---
