---
export const prerender = false;

import { getTranslations, isValidLanguage, type Language } from "@/utils/i18n";
let lang: Language = "es";

// Check for language in cookies
const cookieLang = Astro.cookies.get("lang")?.value;

if (cookieLang && isValidLanguage(cookieLang)) {
  lang = cookieLang;
}

// Check for language in Accept-Language header
const acceptLanguage = Astro.request.headers.get("accept-language");

if (acceptLanguage) {
  const browserLang = acceptLanguage.split(",")[0].split("-")[0];

  if (isValidLanguage(browserLang)) {
    lang = browserLang;
  }
}

const t = getTranslations(lang);

import Layout from "@/layouts/Layout.astro";
---

<style>
  #element-404-1 {
    transform: translate(-200px);
    opacity: 0;
  }
  #element-404-2 {
    transform: translate(200px);
    opacity: 0;
  }
  #element-404-3 {
    transform: translate(-200px);
    opacity: 0;
  }
  #element-404-4 {
    transform: translateY(200px);
    opacity: 0;
  }
</style>

<Layout
  title={t.error_404_page_title || "404 - Página no encontrada | Fravelz"}
  description={t.error_404_description || "Página no encontrada"}
  lang={lang}
>
  <main class="flex h-screen items-center justify-center">
    <!-- Ilustración SVG animada -->
    <div class="absolute inset-0 my-8 flex items-center justify-center">
      <svg
        id="animation-404-circle"
        class="h-64 w-64 overflow-visible text-cyan-500/30 sm:h-80 sm:w-80 dark:text-cyan-400/20"
        viewBox="0 0 200 200"
        xmlns="http://www.w3.org/2000/svg"
      >
        <!-- Círculo exterior animado -->
        <circle
          cx="100"
          cy="100"
          r="80"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-dasharray="5,5"
          class="animate-spin"
          style="animation-duration: 20s;"></circle>

        <!-- Círculo medio -->
        <circle
          cx="100"
          cy="100"
          r="50"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          opacity="0.5"></circle>

        <!-- Círculo interior -->
        <circle
          cx="100"
          cy="100"
          r="20"
          fill="currentColor"
          opacity="0.3"
          class="animate-pulse"></circle>

        <!-- Punto central -->
        <circle cx="100" cy="100" r="5" fill="currentColor"></circle>
      </svg>
    </div>

    <div class="w-full max-w-2xl space-y-8 text-center">
      <!-- Número 404 con animación -->
      <div class="relative">
        <h1
          id="element-404-1"
          class="animate-pulse bg-gradient-to-r from-cyan-400 via-purple-400 to-cyan-400 bg-clip-text text-9xl font-bold text-transparent sm:text-[12rem]"
        >
          404
        </h1>
        <div
          class="absolute inset-0 text-9xl font-bold text-cyan-500/20 blur-2xl sm:text-[12rem]"
        >
          404
        </div>
      </div>

      <!-- Mensaje principal -->
      <div class="space-y-4">
        <h2
          id="element-404-2"
          class="text-3xl font-bold text-gray-800 sm:text-4xl dark:text-gray-100"
          data-i18n="error_404_title"
        >
          {t.error_404_title}
        </h2>

        <p
          id="element-404-3"
          class="mx-auto max-w-md text-base text-gray-600 sm:text-lg dark:text-gray-400"
          data-i18n="error_404_description"
        >
          {t.error_404_description}
        </p>
      </div>

      <!-- Botón para volver al inicio -->
      <div id="element-404-4" class="pt-4">
        <a
          href={`/${lang}/`}
          class="inline-flex cursor-pointer items-center gap-2 rounded-xl bg-gradient-to-r from-cyan-500 to-purple-500 px-6 py-3 text-lg font-bold text-white transition-all duration-300 hover:scale-105 hover:from-cyan-400 hover:to-purple-400 hover:shadow-2xl hover:shadow-cyan-500/50 active:scale-95"
          data-i18n="error_404_back_home"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-5 w-5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
          </svg>
          {t.error_404_back_home}
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  // import { runAnimation } from "@/scripts-animations/404.ts";

  import gsap from "gsap";
  const tl = gsap.timeline();

  tl.to("#element-404-1", {
    x: 0,
    opacity: 1,
    duration: 0.6,
    ease: "power3.out",
  })
    .to("#element-404-2", {
      x: 0,
      opacity: 1,
      duration: 0.6,
      ease: "power3.out",
    })
    .to("#element-404-3", {
      x: 0,
      opacity: 1,
      duration: 0.6,
      ease: "power3.out",
    })
    .to("#element-404-4", {
      y: 0,
      opacity: 1,
      duration: 0.6,
      ease: "power3.out",
    });

  // runAnimation();
</script>
