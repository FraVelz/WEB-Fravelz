---
import clsx from "clsx";
---

<!-- Overlay — scrim oscuro (tokens: --color-black) -->
<div
  data-drawer-overlay
  class={clsx(
    "pointer-events-none fixed inset-0 z-50 bg-[rgb(var(--color-black)/0.45)] opacity-0 backdrop-blur-sm",
    "transition-opacity duration-300 lg:hidden",
  )}
>
</div>

<!-- Panel — superficie opaca alineada con --color-surface (no bg-white suelto) -->
<aside
  id="drawer-menu"
  data-drawer
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
  class={clsx(
    "drawer-panel fixed top-0 right-0 z-[60] h-dvh w-[85%] max-w-sm translate-x-full transform overflow-y-auto",
    "bg-[rgb(var(--color-surface))] shadow-2xl transition-transform duration-300 ease-in-out lg:hidden",
  )}
>
  <!-- Cabecera — mismo fondo sólido que el panel (evita “transparencia” al hacer scroll) -->
  <div
    class={clsx(
      "sticky top-0 z-10 flex items-center justify-between border-b border-[rgb(var(--color-drawer-border))]",
      "bg-[rgb(var(--color-surface))] p-5",
    )}
  >
    <span
      class="text-lg font-semibold text-[rgb(var(--color-text))]"
      data-i18n="nav_menu">Menú</span
    >

    <button
      data-drawer-close
      aria-label="Cerrar menú"
      data-i18n-attr="aria-label:nav_close_menu"
      class={clsx(
        "text-2xl text-[rgb(var(--color-text))] transition-colors",
        "hover:text-[rgb(var(--color-primary))] dark:hover:text-[rgb(var(--color-white))]",
      )}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-6"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18 18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Contenido -->
  <div class="flex flex-col gap-5 bg-[rgb(var(--color-surface))] p-5">
    <slot />
  </div>
</aside>

<style>
  /* Refuerzo opaco por si alguna utilidad de Tailwind no aplica el token en runtime */
  .drawer-panel {
    background-color: rgb(var(--color-surface));
  }
</style>

<script is:inline>
  (function () {
    const openBtn = document.querySelector("[data-drawer-open]");
    const closeBtn = document.querySelector("[data-drawer-close]");
    const drawer = document.querySelector("[data-drawer]");
    const overlay = document.querySelector("[data-drawer-overlay]");

    const openDrawer = () => {
      drawer?.classList.remove("translate-x-full");
      overlay?.classList.remove("opacity-0", "pointer-events-none");
      openBtn?.setAttribute("aria-expanded", "true");

      // Reinicializar scripts cuando se abre el drawer
      // Esto asegura que los selectores y toggles funcionen
      setTimeout(() => {
        // Disparar evento personalizado para que los componentes se reinicialicen si es necesario
        window.dispatchEvent(new CustomEvent("drawer-opened"));
      }, 100);
    };

    const closeDrawer = () => {
      drawer?.classList.add("translate-x-full");
      overlay?.classList.add("opacity-0", "pointer-events-none");
      openBtn?.setAttribute("aria-expanded", "false");
    };

    openBtn?.addEventListener("click", openDrawer);
    closeBtn?.addEventListener("click", closeDrawer);
    overlay?.addEventListener("click", closeDrawer);
  })();
</script>
