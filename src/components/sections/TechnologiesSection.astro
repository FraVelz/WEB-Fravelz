---
import { getTranslations, type Language } from "@/utils/i18n";

const lang = Astro.params.lang as Language;
const t = getTranslations(lang);

interface Technology {
  id: string;
  name: string;
  level: string;
  levelKey: string;
  category: "frontend" | "backend" | "both";
  categoryKey: string;
  svg: string;
  color: string;
  darkColor: string;
}

