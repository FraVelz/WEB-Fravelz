# Public site URL (Open Graph, sitemap). Vercel sets VERCEL_URL automatically.
NEXT_PUBLIC_SITE_URL=https://fravelz.vercel.app

# Sentry (optional). Client init no-ops when unset. Use a low-traffic project DSN.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# Optional server override (falls back to NEXT_PUBLIC_SENTRY_DSN):
# SENTRY_DSN=
