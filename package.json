{
  "name": "fravelz-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "style": "pnpm run format && pnpm run lint:fix",
    "react:doctor": "react-doctor . --verbose --full"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-doctor": "^0.1.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
